APP_NAME="Enterprise RAG Knowledge Assistant"
APP_ENV="local"
OPENAI_API_KEY="sk-..."
OPENAI_BASE_URL="https://openrouter.ai/api/v1"
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
VECTOR_STORE_BACKEND="sqlite"
VECTOR_DB_PATH="data/vector_store.sqlite3"
POSTGRES_URL="postgresql://rag:rag@localhost:5433/rag"
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE=900
CHUNK_OVERLAP=150

# Reranker: "local" (cross-encoder on CPU, free) | "cohere" (API) | "none" (skip)
RERANKER_BACKEND="local"
RERANKER_MODEL="cross-encoder/ms-marco-MiniLM-L-6-v2"
RERANKER_TOP_N=20
COHERE_API_KEY=""

# JWT authentication
JWT_SECRET="your-secret-key-min-32-chars-change-in-production"
JWT_ALGORITHM="HS256"
RATE_LIMIT_REQUESTS=60       # max requests per user per window
RATE_LIMIT_WINDOW_SECONDS=60 # window size in seconds

# Semantic answer cache (backed by pgvector)
CACHE_TTL_HOURS=24            # how long a cached answer stays valid
CACHE_SEMANTIC_THRESHOLD=0.92 # cosine similarity floor — lower = more cache hits but less precise

# Document sync: scan the docs folder for changes automatically
SYNC_ON_STARTUP=true          # check for changes every time the API starts
SYNC_INTERVAL_SECONDS=300     # also check every 5 minutes while running (0 = off)
